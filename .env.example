# Production template. Copy to .env and replace every CHANGE_ME value.
APP_ENVIRONMENT=production
POSTGRES_DB=iota_ml
POSTGRES_USER=iota_ml
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_DATABASE_PASSWORD
AUTH_SECRET=CHANGE_ME_RANDOM_64_CHARACTER_AUTH_SECRET
CORS_ORIGINS=https://ml.example.com

MINIO_PUBLIC_ENDPOINT=storage.example.com
MINIO_ACCESS_KEY=CHANGE_ME_RANDOM_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_RANDOM_MINIO_SECRET_KEY
MINIO_SECURE=true
ARTIFACT_BUCKET=iota-artifacts

# Optional integrations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
VITE_AMCHARTS_LICENSE_KEY=

# Public frontend port on the deployment host.
HTTP_PORT=8080

# Workflow execution limits
JOB_DEFAULT_TIMEOUT_SECONDS=7200
JOB_WORKER_CONCURRENCY=2
JOB_NETWORK_DISABLED=true
JOB_USE_FORK_FAST_PATH=true
JOB_MEMORY_LIMIT_MB=4096
JOB_CPU_LIMIT_SECONDS=7200
NODE_CACHE_ENABLED=true
NODE_CACHE_RETENTION_DAYS=30
NODE_CACHE_COMPRESSION=3
WORKFLOW_VERSION_LIMIT=100
