POSTGRES_DB=nocodeml
POSTGRES_USER=nocodeml
POSTGRES_PASSWORD=nocodeml
AUTH_SECRET=change-this-secret-in-production
USER_FILE=/app/app/data/user.json

# Reliable workflow execution
JOB_DEFAULT_TIMEOUT_SECONDS=7200
JOB_DEFAULT_MAX_ATTEMPTS=3
JOB_WORKER_CONCURRENCY=2
JOB_HEARTBEAT_INTERVAL_SECONDS=10
JOB_STALE_AFTER_SECONDS=45
JOB_MEMORY_LIMIT_MB=4096
JOB_CPU_LIMIT_SECONDS=7200
JOB_NETWORK_DISABLED=true
MAX_ACTIVE_RUNS_PER_USER=4
MAX_ACTIVE_RUNS_PER_PROJECT=8

# Artifact storage
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=nocodeml
MINIO_SECRET_KEY=change-this-minio-secret
MINIO_SECURE=false
ARTIFACT_BUCKET=iota-artifacts
ARTIFACT_MAX_UPLOAD_BYTES=536870912
ARTIFACT_USER_QUOTA_BYTES=10737418240
ARTIFACT_PROJECT_QUOTA_BYTES=5368709120

# Worker responsiveness
JOB_POLL_INTERVAL_SECONDS=1.0
JOB_ACTIVE_POLL_INTERVAL_SECONDS=0.05
JOB_STATE_POLL_INTERVAL_SECONDS=0.75
JOB_USE_FORK_FAST_PATH=true
JOB_WORKER_HEALTH_INTERVAL_SECONDS=5
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
